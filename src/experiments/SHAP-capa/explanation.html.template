<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Model Explanation</title>

  <!-- Bootstrap CSS (CDN) -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />

  <style>
    body {
      background-color: #f8f9fa;
    }
    .card-title {
      font-weight: 600;
    }
    .num {
      text-align: right;
      font-family: monospace;
      white-space: nowrap;
    }

    /* Row coloring based on IMPACT semantics */
    .impact-increases {
      background-color: #f8d7da !important; /* bootstrap danger-subtle */
    }
    .impact-reduces {
      background-color: #d1e7dd !important; /* bootstrap success-subtle */
    }

    .impact-text {
      white-space: nowrap;
      font-weight: 500;
    }

    pre.json-dump {
      max-height: 300px;
      overflow: auto;
      background: #f1f3f5;
      padding: 1rem;
      border-radius: 0.25rem;
      font-size: 0.85rem;
    }
  </style>
</head>

<body>
<div class="container my-4">

  <!-- ================= Summary ================= -->
  <div class="card mb-4">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center">
        <h4 class="card-title mb-0">Model Explanation</h4>
        <button class="btn btn-sm btn-outline-secondary"
                id="copy-json-btn">
          Copy JSON
        </button>
      </div>

      <div class="row mt-3">
        <div class="col-md-3"><strong>Type</strong></div>
        <div class="col-md-9" id="summary-type"></div>

        <div class="col-md-3"><strong>Baseline</strong></div>
        <div class="col-md-9 num" id="summary-baseline"></div>

        <div class="col-md-3"><strong>Final logit</strong></div>
        <div class="col-md-9 num" id="summary-logit"></div>

        <div class="col-md-3"><strong>Final probability</strong></div>
        <div class="col-md-9 num" id="summary-prob"></div>
      </div>
    </div>
  </div>

  <!-- ================= Logit / Prob Explanation ================= -->
  <div class="card mb-4">
    <div class="card-body">
      <h5 class="card-title">Interpretation Notes</h5>
      <p class="mb-0">
        This explanation is expressed in
        <strong id="explanation-space"></strong>.
        Each contribution represents an additive change in that space.
        <br><br>
        When the explanation type is <strong>logit</strong>, contributions
        increase or reduce the model’s log-odds for the
        <strong>positive (MALWARE)</strong> class. The final probability
        is obtained by applying the logistic function to the summed logits.
        <br><br>
        When the explanation type is <strong>prob</strong>, contributions
        directly add or subtract probability mass for the positive class.
      </p>
    </div>
  </div>

  <!-- ================= Tables ================= -->
  <div id="tables-root"></div>

  <!-- ================= Raw JSON ================= -->
  <div class="card mb-4">
    <div class="card-body">
      <button class="btn btn-sm btn-outline-primary mb-2"
              data-bs-toggle="collapse"
              data-bs-target="#jsonCollapse">
        Toggle Raw JSON
      </button>
      <div class="collapse" id="jsonCollapse">
        <pre class="json-dump" id="json-dump"></pre>
      </div>
    </div>
  </div>

</div>

<!-- Bootstrap JS -->
<script
  src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
</script>

<script>
/* ============================================================
   🔴 PLACEHOLDER (DO NOT CHANGE SHAPE)
   ============================================================ */
const EXPLANATION_DATA = [[EXPLANATION_DATA]];

/* ================= Utility ================= */

function formatNumber(x) {
  if (typeof x !== "number") return "";
  const abs = Math.abs(x);
  if (abs !== 0 && (abs < 1e-4 || abs >= 1e4)) {
    return x.toExponential(6);
  }
  return x.toFixed(6);
}

function impactRowClass(impactText) {
  if (typeof impactText !== "string") return "";
  if (impactText.includes("INCREASES")) return "impact-increases";
  if (impactText.includes("REDUCES")) return "impact-reduces";
  return "";
}

/* ================= Rendering ================= */

function renderSummary(data) {
  document.getElementById("summary-type").textContent = data.type;
  document.getElementById("summary-baseline").textContent =
    formatNumber(data.baseline);
  document.getElementById("summary-logit").textContent =
    formatNumber(data.logit);
  document.getElementById("summary-prob").textContent =
    formatNumber(data.prob);

  document.getElementById("explanation-space").textContent =
    data.type === "logit" ? "logit space" : "probability space";
}

function renderTable(title, idSuffix, contributions) {
  const ENABLE_FEATURE_VALUES = (contributions.length > 0 && typeof contributions[0].value === 'number');

  const card = document.createElement("div");
  card.className = "card mb-4";

  card.innerHTML = `
    <div class="card-body">
      <button class="btn btn-sm btn-outline-primary mb-2"
              data-bs-toggle="collapse"
              data-bs-target="#collapse-${idSuffix}">
        Toggle ${title}
      </button>

      <div class="collapse" id="collapse-${idSuffix}">
        <h5 class="card-title">${title}</h5>
        <div class="table-responsive">
          <table class="table table-sm table-striped align-middle">
            <thead class="table-light">
              <tr>
                <th>Name</th>
                ${ENABLE_FEATURE_VALUES ? '<th class="num">Value</th>' : ''}
                <th class="num">Contribution</th>
                <th>Impact</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>
  `;

  const tbody = card.querySelector("tbody");

  if (!Array.isArray(contributions) || contributions.length === 0) {
    const tr = document.createElement("tr");
    tr.innerHTML = `<td colspan="3" class="text-muted">No data</td>`;
    tbody.appendChild(tr);
  } else {
    for (const c of contributions) {
      const tr = document.createElement("tr");
    //   tr.className = impactRowClass(c.impact);
      tr.innerHTML = `
        <td>${c.name}</td>
        ${ENABLE_FEATURE_VALUES ? `<td class="num">${formatNumber(c.value)}</td>` : ''}
        <td class="num">${formatNumber(c.contribution)}</td>
        <td class="impact-text ${impactRowClass(c.impact)}">${c.impact}</td>
      `;
      tbody.appendChild(tr);
    }
  }

  return card;
}

function renderAll(data) {
  renderSummary(data);

  document.getElementById("json-dump").textContent =
    JSON.stringify(data, null, 2);

  const root = document.getElementById("tables-root");
  root.innerHTML = "";

  root.appendChild(
    renderTable(
      "Contributing Features",
      "features",
      data.sorted_contributing_features
    )
  );

  root.appendChild(
    renderTable(
      "Contributing Feature Groups",
      "groups",
      data.sorted_contributing_feature_groups
    )
  );

  root.appendChild(
    renderTable(
      "Contributing Feature Categories",
      "categories",
      data.sorted_contributing_feature_categories
    )
  );
}

/* ================= Copy JSON ================= */

document.getElementById("copy-json-btn").addEventListener("click", () => {
  const text = JSON.stringify(EXPLANATION_DATA, null, 2);
  navigator.clipboard.writeText(text).then(() => {
    alert("JSON copied to clipboard");
  });
});

/* ================= Bootstrap ================= */

try {
  renderAll(EXPLANATION_DATA);
} catch (e) {
  console.error(e);
  alert("Failed to render explanation: invalid or missing data.");
}
</script>

</body>
</html>
